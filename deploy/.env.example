# Copy to deploy/.env and edit, then:
#   docker compose -f deploy/compose.postgres.yaml --env-file deploy/.env up -d

# Image to run (build with: ./mvnw -Pdocker -pl unitrack-web -am package)
UNITRACK_IMAGE=unitrack:0.1.0-SNAPSHOT
UNITRACK_PORT=8080

# PostgreSQL (compose.postgres.yaml)
POSTGRES_DB=unitrack
POSTGRES_USER=unitrack
POSTGRES_PASSWORD=change-me

# Optional GitHub commit-status integration (unitrack.github.*)
# UNITRACK_GITHUB_ENABLED=true
# UNITRACK_GITHUB_TOKEN=ghp_xxx
# UNITRACK_GITHUB_SERVERBASEURL=https://unitrack.example
